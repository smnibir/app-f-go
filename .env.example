# =============================================================================
# Local setup (required for Prisma CLI: migrate, db pull, etc.)
# Copy this file to `.env` in the project root (same folder as package.json):
#   cp .env.example .env
# Set DATABASE_URL and DIRECT_URL (here or in `.env.local`). Both are required by Prisma.
# If you use a single Postgres (no pooler), set DIRECT_URL to the same value as DATABASE_URL.
# `npm run db:migrate:deploy` loads `.env` then `.env.local`.
# =============================================================================

# --- Database ---
# Supabase app traffic: Settings → Database → Connection pooling / Transaction (port 6543).
# Must start with postgresql:// or postgres://. URL-encode special chars in the password.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
# Same project → Settings → Database → Connection string → URI → use "Direct connection" (port 5432, host like db.xxxxx.supabase.co). Prisma runs migrations against this URL.
# Local Docker / single URL: copy DATABASE_URL here or use the same connection string twice.
DIRECT_URL="postgresql://USER:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

# openssl rand -base64 32  (required — login/session will not work without it)
AUTH_SECRET=""

# Must match the URL users open in the browser (https, no path). On Vercel set to:
#   https://YOUR-PROJECT.vercel.app   or your custom domain
# (Do not rely on VERCEL_URL alone for Auth.js cookies.)
NEXTAUTH_URL="https://your-domain.com"

# --- Vercel: Project → Settings → Environment Variables
# DATABASE_URL and DIRECT_URL (Supabase: pooler + direct 5432) — Production, Preview, and Build.
# (Build runs `prisma migrate deploy`, which needs both URLs when using a pooler.)
# Same for AUTH_SECRET / NEXTAUTH_URL as needed for a successful build if your app imports them at build time.
# After deploy: GET https://YOUR-APP.vercel.app/api/health — database should be "ok".

# --- Production database migration (run from YOUR machine; never commit secrets) ---
# Option A — one line:
#   DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?sslmode=require" npx prisma migrate deploy
#
# Option B — file (gitignored): create `.env.production` with only DATABASE_URL=... for prod, then:
#   npm run db:migrate:production
#
# Option C — Vercel CLI:
#   vercel env pull .env.production
#   npm run db:migrate:production

# --- Seed (first deploy / local only) ---
# SEED_SUPER_ADMIN_EMAIL="admin@example.com"
# SEED_SUPER_ADMIN_PASSWORD="change-me-after-first-login"

# --- Optional ---
# NEXTAUTH_SECRET=""
# AUTH_URL=""
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL=""
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
